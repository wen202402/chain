{
  "name": "wen202402/chain",
  "type": "library",
  "description": "A small PHP library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "iexbase/tron-api": "^5.0"
  },

  "autoload": {
    "psr-4": {
      "wen202402\\chain\\": "src/"
    }
  },

  "config": {
    "process-timeout": 1800,
    "fxp-asset": {
      "enabled": false
    },
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true

    }
  }
}
